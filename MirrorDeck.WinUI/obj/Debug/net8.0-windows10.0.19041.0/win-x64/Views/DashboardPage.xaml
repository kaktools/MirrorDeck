<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="MirrorDeck.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:ConnectionId='2' x:Name="DashboardRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel Padding="14" Spacing="14">
                <Border x:ConnectionId='3' Style="{StaticResource ActionCard}"                                                                       >
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="AirPlay" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                <TextBlock Text="Status:" Style="{StaticResource BodySubtleStyle}" VerticalAlignment="Center" />
                                <TextBlock x:ConnectionId='25'                                                                 Foreground="{StaticResource MdTextStrongBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel x:ConnectionId='20' Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center"                                                                          >
                                <Border x:ConnectionId='21' Style="{StaticResource StatusBadgeStyle}"                                                                                                                                        >
                                    <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Bonjour" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='24'                                                          Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                </Border>
                                <Border x:ConnectionId='22' Style="{StaticResource StatusBadgeStyle}"                                                                                                                                      >
                                    <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="UxPlay" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='23'                                                         Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:ConnectionId='17' Grid.Column="0" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78"                                                      >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Play" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="Start" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="AirPlay-Mirror starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button x:ConnectionId='18' Grid.Column="1" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E"                                                     >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Stop" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Stop" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="AirPlay-Mirror stoppen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button x:ConnectionId='19' Grid.Column="2" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF"                                                        >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="AirPlay neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:ConnectionId='4' Style="{StaticResource ActionCard}"                                                                       >
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Android" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                <TextBlock Text="Status:" Style="{StaticResource BodySubtleStyle}" VerticalAlignment="Center" />
                                <TextBlock x:ConnectionId='16'                                                                 Foreground="{StaticResource MdTextStrongBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel x:ConnectionId='13' Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center"                                                                          >
                                <Border x:ConnectionId='14' Style="{StaticResource StatusBadgeStyle}"                                                                                                                                      >
                                    <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="scrcpy" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='15'                                                         Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:ConnectionId='10' Grid.Column="0" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78"                                                         >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Play" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="Start" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Android-Mirror starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button x:ConnectionId='11' Grid.Column="1" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E"                                                     >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Stop" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Stop" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Android-Mirror stoppen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button x:ConnectionId='12' Grid.Column="2" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF"                                                        >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Android neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:ConnectionId='5' Style="{StaticResource StatusCard}"                                                                     >
                    <StackPanel Spacing="10">
                        <TextBlock Text="Globale Aktionen" Style="{StaticResource SectionTitleStyle}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:ConnectionId='6' Grid.Column="0" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF"                                               >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart All" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Alle laufenden Sessions neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button x:ConnectionId='7' Grid.Column="1" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdPauseCardBrush}" BorderBrush="#66D79832"                                                >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Pause" Foreground="{StaticResource MdWarningBrush}" />
                                            <TextBlock Text="Pause / Play" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock x:ConnectionId='9'                                                         Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button x:ConnectionId='8' Grid.Column="2" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSnapshotCardBrush}" BorderBrush="#6622B8CF"                                             >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <SymbolIcon Grid.Column="0" Symbol="Camera" Foreground="{StaticResource MdInfoBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="Snapshot" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="Fenster-Screenshot erstellen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" HorizontalAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

