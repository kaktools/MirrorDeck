<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="MirrorDeck.WinUI.Views.AirPlayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:ConnectionId='2' x:Name="AirPlayRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel Padding="14" Spacing="14">
                <Border Style="{StaticResource PageHeaderCard}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="AirPlay" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
                            <ScrollViewer Grid.Column="1" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Hidden" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Bonjour" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='14'                                                             Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Dienst" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='13'                                                           Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}" Background="#1F2FBF78" BorderBrush="#4A2FBF78"><TextBlock x:ConnectionId='12'                                                          Foreground="{StaticResource MdTextStrongBrush}" /></Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="UxPlay-Empfänger starten und Bonjour-Status kontrollieren" Style="{StaticResource BodySubtleStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource ActionCard}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Grid ColumnSpacing="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch x:ConnectionId='11' Grid.Column="0" Width="52" MinWidth="0" Padding="0" Margin="0,0,-6,0" Header="" OnContent="" OffContent=""                                                            VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <TextBlock Grid.Column="1" Text="Auto-Start" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Grid ColumnSpacing="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch x:ConnectionId='10' Grid.Column="0" Width="52" MinWidth="0" Padding="0" Margin="0,0,-6,0" Header="" OnContent="" OffContent=""                                                             VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <TextBlock Grid.Column="1" Text="Auto-Restart" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0" />
                            </Grid>
                        </StackPanel>

                        <ItemsControl>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid Orientation="Horizontal" HorizontalAlignment="Left" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                                <Button x:ConnectionId='4' Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78"                                          >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Play" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="Start" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="UxPlay-Empfänger starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button x:ConnectionId='5' Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E"                                         >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Stop" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Stop" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="UxPlay stoppen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button x:ConnectionId='6' Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF"                                            >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="UxPlay neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button x:ConnectionId='7' Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSnapshotCardBrush}" BorderBrush="#6622B8CF"                                                         >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="World" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Bonjour-Status" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Dienststatus aktualisieren" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button x:ConnectionId='8' Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdPauseCardBrush}" BorderBrush="#66D79832"                                                   >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Sync" Foreground="{StaticResource MdWarningBrush}" />
                                            <TextBlock Text="Bonjour neu starten" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Bonjour-Service resetten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button x:ConnectionId='9' Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSurfaceAltBrush}" BorderBrush="#55334661"                                            >
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Copy" Foreground="{StaticResource MdTextStrongBrush}" />
                                            <TextBlock Text="Log kopieren" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Aktuelle AirPlay-Logs kopieren" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Expander Header="Logs anzeigen" IsExpanded="False" HorizontalAlignment="Stretch">
                    <Border Style="{StaticResource LogPanelStyle}" Margin="0,8,0,0">
                        <ScrollViewer MinHeight="180" MaxHeight="260">
                            <TextBlock x:ConnectionId='3'
                                                                              
                                TextWrapping="Wrap"
                                IsTextSelectionEnabled="True"
                                Foreground="{StaticResource MdTextStrongBrush}"
                                FontFamily="{StaticResource MirrorDeckMonoFont}" />
                        </ScrollViewer>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

