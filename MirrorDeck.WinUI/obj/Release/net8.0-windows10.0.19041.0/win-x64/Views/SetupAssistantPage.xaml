<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="MirrorDeck.WinUI.Views.SetupAssistantPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
                           >

    <Grid x:ConnectionId='2' x:Name="SetupRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel x:ConnectionId='3' x:Name="SetupContent" Padding="14" Spacing="14">
                <Border Style="{StaticResource PageHeaderCard}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Setup &amp; Einstellungen" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
                        <Button x:ConnectionId='27'
                            Grid.Column="1"
                            Content="Lizenz"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButtonStyle}"
                                                               />
                    </Grid>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Live-Status:" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <ScrollViewer Grid.Column="1" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Hidden" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="3"><TextBlock Text="UxPlay" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='26'                                                    FontSize="11" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="3"><TextBlock Text="scrcpy" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='25'                                                    FontSize="11" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="3"><TextBlock Text="adb" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='24'                                                 FontSize="11" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="3"><TextBlock Text="Bonjour" Style="{StaticResource BodySubtleStyle}" /><TextBlock x:ConnectionId='23'                                                     FontSize="11" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusCard}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="App-Verhalten &amp; Module" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <ComboBox x:ConnectionId='22' Grid.Column="1"                                                      MinWidth="160" HorizontalAlignment="Right">
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                            </ComboBox>
                        </Grid>
                        <Grid ColumnSpacing="20" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <CheckBox x:ConnectionId='13' Grid.Row="0" Grid.Column="0" Content="Minimiert starten"                                                            Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='14' Grid.Row="0" Grid.Column="1" Content="Beim Schließen in Tray minimieren"                                                            Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='15' Grid.Row="1" Grid.Column="0" Content="Mit Windows starten"                                                              Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='16' Grid.Row="1" Grid.Column="1" Content="Abhängigkeiten auto prüfen"                                                                 Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='17' Grid.Row="2" Grid.Column="0" Content="AirPlay-Modul aktiv"                                                                  Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='18' Grid.Row="2" Grid.Column="1" Content="Android-Modul aktiv"                                                                  Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='19' Grid.Row="3" Grid.Column="0" Content="Windows-Benachrichtigungen aktivieren"                                                                        Foreground="{StaticResource MdTextStrongBrush}" />
                            <Button x:ConnectionId='20' Grid.Row="3" Grid.Column="1" Content="AirPlay reparieren" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}"                                                   />
                            <CheckBox x:ConnectionId='21' Grid.Row="4" Grid.Column="0" Content="Erststart-Auswahl beim nächsten Start"                                                                        Foreground="{StaticResource MdTextStrongBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Update &amp; Support" Style="{StaticResource SectionTitleStyle}" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button x:ConnectionId='10' Grid.Column="0" Content="Update prüfen" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"                              />
                            <Button x:ConnectionId='11' x:Name="UpdateInstallButton" Grid.Column="1" Content="Update installieren" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" IsEnabled="False"                                />
                            <Button x:ConnectionId='12' Grid.Column="2" Style="{StaticResource CoffeeButtonStyle}" HorizontalAlignment="Stretch"                             >
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xECAF;" FontSize="16" />
                                    <TextBlock Text="Buy me a coffee" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Shortcuts" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="In ein Feld klicken und den nächsten Tastaturbefehl drücken." Style="{StaticResource BodySubtleStyle}" TextWrapping="WrapWholeWords" />
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Shortcut Snapshot" Style="{StaticResource BodySubtleStyle}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:ConnectionId='8'
                                        x:Name="SnapshotShortcutBox"
                                        Grid.Column="0"
                                                                                               
                                        IsReadOnly="True"
                                        MinWidth="170"
                                        PlaceholderText="Taste drücken"
                                                                           />
                                    <Button x:ConnectionId='9' Grid.Column="1" Content="Zurücksetzen" Style="{StaticResource SecondaryButtonStyle}"                                 />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Shortcut Pause/Play" Style="{StaticResource BodySubtleStyle}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:ConnectionId='6'
                                        x:Name="PauseShortcutBox"
                                        Grid.Column="0"
                                                                                                  
                                        IsReadOnly="True"
                                        MinWidth="170"
                                        PlaceholderText="Taste drücken"
                                                                        />
                                    <Button x:ConnectionId='7' Grid.Column="1" Content="Zurücksetzen" Style="{StaticResource SecondaryButtonStyle}"                              />
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:ConnectionId='5' x:Name="ShortcutCaptureHint" Text="" Style="{StaticResource BodySubtleStyle}" />
                    </StackPanel>
                </Border>

                <TextBlock x:ConnectionId='4'                                                     Style="{StaticResource BodySubtleStyle}" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

