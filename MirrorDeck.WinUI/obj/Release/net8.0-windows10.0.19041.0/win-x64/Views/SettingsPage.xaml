<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="MirrorDeck.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:ConnectionId='2' x:Name="SettingsRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel x:ConnectionId='3' x:Name="SettingsContent" Padding="14" Spacing="12">
                <Border Style="{StaticResource PageHeaderCard}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Einstellungen" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Konfiguration für Verhalten, Dienste und Verbindungsdaten" Style="{StaticResource BodySubtleStyle}" />
                        </StackPanel>
                        <Button x:ConnectionId='19'
                            Grid.Column="1"
                            Content="Lizenz"
                            VerticalAlignment="Top"
                            Style="{StaticResource SecondaryButtonStyle}"
                                                               />
                    </Grid>
                </Border>

                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource StatusCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Allgemein" Style="{StaticResource SectionTitleStyle}" />
                            <ComboBox x:ConnectionId='13' Header="Design"                                                     >
                                <x:String>Default</x:String>
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                            </ComboBox>
                            <CheckBox x:ConnectionId='14' Content="Minimiert starten"                                                            Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='15' Content="Beim Schließen in den Tray minimieren"                                                            Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='16' Content="Mit Windows starten"                                                              Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='17' Content="Windows-Benachrichtigungen aktivieren"                                                                        Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='18' Content="Abhängigkeiten automatisch prüfen"                                                                 Foreground="{StaticResource MdTextStrongBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource InfoCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Dienste" Style="{StaticResource SectionTitleStyle}" />
                            <CheckBox x:ConnectionId='10' Content="AirPlay-Dienst aktivieren"                                                                  Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='11' Content="Android-Dienst aktivieren"                                                                  Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox x:ConnectionId='12' Content="UxPlay/scrcpy nur im Hintergrund ausführen"                                                               Foreground="{StaticResource MdTextStrongBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource StatusCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Verbindung" Style="{StaticResource SectionTitleStyle}" />
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox x:ConnectionId='8' Grid.Row="0" Header="Android TCP/IP-Host"                                                       />
                            <NumberBox x:ConnectionId='9' Grid.Row="1" Header="TCP/IP-Port"                                                        />
                        </Grid>
                        <TextBlock x:ConnectionId='7'                                                     Style="{StaticResource BodySubtleStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Update &amp; Support" Style="{StaticResource SectionTitleStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:ConnectionId='5' Content="Update prüfen" Style="{StaticResource SecondaryButtonStyle}"                              />
                            <Button x:ConnectionId='6' Content="Update installieren" Style="{StaticResource PrimaryButtonStyle}"                                />
                        </StackPanel>
                        <Button x:ConnectionId='4' Style="{StaticResource CoffeeButtonStyle}" HorizontalAlignment="Left"                             >
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xECAF;" FontSize="16" />
                                <TextBlock Text="Buy me a coffee" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

