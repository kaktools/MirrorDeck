<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="MirrorDeck.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="MirrorDeckDisplayFont">Bahnschrift SemiBold</FontFamily>
            <FontFamily x:Key="MirrorDeckBodyFont">Segoe UI Variable Text</FontFamily>
            <FontFamily x:Key="MirrorDeckMonoFont">Cascadia Mono</FontFamily>

            <x:Double x:Key="MdSpaceXs">4</x:Double>
            <x:Double x:Key="MdSpaceSm">8</x:Double>
            <x:Double x:Key="MdSpaceMd">12</x:Double>
            <x:Double x:Key="MdSpaceLg">16</x:Double>
            <x:Double x:Key="MdSpaceXl">20</x:Double>

            <Color x:Key="MdColorBackground">#0B1428</Color>
            <Color x:Key="MdColorSurface">#12233B</Color>
            <Color x:Key="MdColorSurfaceAlt">#0E1D31</Color>
            <Color x:Key="MdColorBorder">#30FFFFFF</Color>
            <Color x:Key="MdColorTextStrong">#F4F8FF</Color>
            <Color x:Key="MdColorTextMuted">#AFC4DA</Color>
            <Color x:Key="MdColorInfo">#64C8FF</Color>
            <Color x:Key="MdColorSuccess">#2FBF78</Color>
            <Color x:Key="MdColorWarning">#D79832</Color>
            <Color x:Key="MdColorDanger">#E45A6E</Color>

            <SolidColorBrush x:Key="MdBackgroundBrush" Color="{StaticResource MdColorBackground}" />
            <SolidColorBrush x:Key="MdSurfaceBrush" Color="{StaticResource MdColorSurface}" />
            <SolidColorBrush x:Key="MdSurfaceAltBrush" Color="{StaticResource MdColorSurfaceAlt}" />
            <SolidColorBrush x:Key="MdBorderBrush" Color="{StaticResource MdColorBorder}" />
            <SolidColorBrush x:Key="MdTextStrongBrush" Color="{StaticResource MdColorTextStrong}" />
            <SolidColorBrush x:Key="MdTextMutedBrush" Color="{StaticResource MdColorTextMuted}" />
            <SolidColorBrush x:Key="MdInfoBrush" Color="{StaticResource MdColorInfo}" />
            <SolidColorBrush x:Key="MdSuccessBrush" Color="{StaticResource MdColorSuccess}" />
            <SolidColorBrush x:Key="MdWarningBrush" Color="{StaticResource MdColorWarning}" />
            <SolidColorBrush x:Key="MdDangerBrush" Color="{StaticResource MdColorDanger}" />
            <SolidColorBrush x:Key="MdBadgeBorderBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="MdBadgeBackgroundBrush" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="MdSecondaryButtonBrush" Color="#2B3A52" />
            <SolidColorBrush x:Key="MdNeutralButtonBrush" Color="#334661" />
            <SolidColorBrush x:Key="MdTitleBarBackgroundBrush" Color="#12233B" />
            <SolidColorBrush x:Key="MdTitleBarSubtleTextBrush" Color="#CFE0F5" />

            <LinearGradientBrush x:Key="MdStartCardBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2A58D0FF" Offset="0" />
                <GradientStop Color="#1A12233B" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="MdStopCardBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2EDC6A7D" Offset="0" />
                <GradientStop Color="#1A12233B" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="MdRestartCardBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2E56B8FF" Offset="0" />
                <GradientStop Color="#1A12233B" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="MdPauseCardBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2E5CD3B6" Offset="0" />
                <GradientStop Color="#1A12233B" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="MdSnapshotCardBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2E5BB4FF" Offset="0" />
                <GradientStop Color="#1A12233B" Offset="1" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="MirrorDeckPageBackgroundBrush" Color="{StaticResource MdColorBackground}" />
            <SolidColorBrush x:Key="MirrorDeckBrandGradientBrush" Color="{StaticResource MdColorInfo}" />
            <SolidColorBrush x:Key="MirrorDeckTextStrongBrush" Color="{StaticResource MdColorTextStrong}" />
            <SolidColorBrush x:Key="MirrorDeckTextMutedBrush" Color="{StaticResource MdColorTextMuted}" />
            <SolidColorBrush x:Key="MirrorDeckCardBrush" Color="{StaticResource MdColorSurface}" />
            <SolidColorBrush x:Key="MirrorDeckCardAltBrush" Color="{StaticResource MdColorSurfaceAlt}" />
            <SolidColorBrush x:Key="MirrorDeckBorderBrush" Color="{StaticResource MdColorBorder}" />
            <SolidColorBrush x:Key="MirrorDeckSuccessBrush" Color="{StaticResource MdColorSuccess}" />
            <SolidColorBrush x:Key="MirrorDeckWarningBrush" Color="{StaticResource MdColorWarning}" />
            <SolidColorBrush x:Key="MirrorDeckDangerBrush" Color="{StaticResource MdColorDanger}" />

            <Style x:Key="PageWatermarkImageStyle" TargetType="Image">
                <Setter Property="Source" Value="ms-appx:///Assets/MirrorDeckLogo.png" />
                <Setter Property="Opacity" Value="0.06" />
                <Setter Property="Stretch" Value="Uniform" />
                <Setter Property="Width" Value="560" />
                <Setter Property="Height" Value="560" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="IsHitTestVisible" Value="False" />
            </Style>

            <Style x:Key="PageHeaderCard" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource MdSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource MdBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="ActionCard" TargetType="Border" BasedOn="{StaticResource PageHeaderCard}">
                <Setter Property="Padding" Value="12" />
            </Style>

            <Style x:Key="StatusCard" TargetType="Border" BasedOn="{StaticResource PageHeaderCard}">
                <Setter Property="Padding" Value="12" />
            </Style>

            <Style x:Key="InfoCard" TargetType="Border" BasedOn="{StaticResource PageHeaderCard}">
                <Setter Property="Background" Value="{StaticResource MdSurfaceAltBrush}" />
                <Setter Property="Padding" Value="12" />
            </Style>

            <Style x:Key="LogPanelStyle" TargetType="Border" BasedOn="{StaticResource InfoCard}">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="10" />
            </Style>

            <Style x:Key="ActionToneCardStyle" TargetType="Border" BasedOn="{StaticResource PageHeaderCard}">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="MinWidth" Value="230" />
            </Style>

            <Style x:Key="ActionTileButtonStyle" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource MirrorDeckBodyFont}" />
                <Setter Property="Foreground" Value="{StaticResource MdTextStrongBrush}" />
                <Setter Property="Background" Value="{StaticResource MdSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource MdBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="Width" Value="216" />
                <Setter Property="Height" Value="84" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="StatusBadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource MdBadgeBorderBrush}" />
                <Setter Property="Background" Value="{ThemeResource MdBadgeBackgroundBrush}" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource MirrorDeckBodyFont}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="{StaticResource MdInfoBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="MinHeight" Value="34" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Background" Value="{ThemeResource MdSecondaryButtonBrush}" />
                <Setter Property="Foreground" Value="{StaticResource MdTextStrongBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource MdBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Background" Value="{StaticResource MdDangerBrush}" />
            </Style>

            <Style x:Key="WarnButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Background" Value="{StaticResource MdWarningBrush}" />
            </Style>

            <Style x:Key="NeutralButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Background" Value="{ThemeResource MdNeutralButtonBrush}" />
                <Setter Property="Foreground" Value="{StaticResource MdTextStrongBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource MdBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="CoffeeButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Background" Value="#F5C542" />
                <Setter Property="Foreground" Value="#2F2400" />
                <Setter Property="BorderBrush" Value="#D6A11E" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource MirrorDeckDisplayFont}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource MdTextStrongBrush}" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource MirrorDeckDisplayFont}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Foreground" Value="{StaticResource MdTextStrongBrush}" />
            </Style>

            <Style x:Key="BodySubtleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource MirrorDeckBodyFont}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource MdTextMutedBrush}" />
            </Style>

            <Style x:Key="SidebarGlyphIconStyle" TargetType="FontIcon">
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Foreground" Value="{StaticResource MdTextStrongBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="MirrorDeckCardStyle" TargetType="Border" BasedOn="{StaticResource StatusCard}" />
            <Style x:Key="MirrorDeckCardAltStyle" TargetType="Border" BasedOn="{StaticResource InfoCard}" />
            <Style x:Key="MirrorDeckHeroCardStyle" TargetType="Border" BasedOn="{StaticResource PageHeaderCard}" />
            <Style x:Key="MirrorDeckStatusCardStyle" TargetType="Border" BasedOn="{StaticResource StatusCard}" />
            <Style x:Key="MirrorDeckActionCardStyle" TargetType="Border" BasedOn="{StaticResource ActionCard}" />
            <Style x:Key="MirrorDeckSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource PageTitleStyle}" />
            <Style x:Key="MirrorDeckSubTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BodySubtleStyle}" />
            <Style x:Key="MirrorDeckActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />
            <Style x:Key="MirrorDeckSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}" />
            <Style x:Key="MirrorDeckDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}" />
            <Style x:Key="MirrorDeckWarnButtonStyle" TargetType="Button" BasedOn="{StaticResource WarnButtonStyle}" />
            <Style x:Key="MirrorDeckNeutralButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}" />
            <Style x:Key="MirrorDeckChipBorderStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}" />
            <Style x:Key="MirrorDeckStatusBadgeStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}" />
            <Style x:Key="MirrorDeckFieldStyle" TargetType="Control">
                <Setter Property="FontFamily" Value="{StaticResource MirrorDeckBodyFont}" />
                <Setter Property="Foreground" Value="{StaticResource MdTextStrongBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

