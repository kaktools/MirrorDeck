<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MirrorDeck.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="SettingsRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel x:Name="SettingsContent" Padding="14" Spacing="12">
                <Border Style="{StaticResource PageHeaderCard}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Einstellungen" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Konfiguration für Verhalten, Dienste und Verbindungsdaten" Style="{StaticResource BodySubtleStyle}" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Content="Lizenz"
                            VerticalAlignment="Top"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnOpenLicenseWindowClicked" />
                    </Grid>
                </Border>

                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource StatusCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Allgemein" Style="{StaticResource SectionTitleStyle}" />
                            <ComboBox Header="Design" SelectedItem="{x:Bind ViewModel.Theme, Mode=TwoWay}">
                                <x:String>Default</x:String>
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                            </ComboBox>
                            <CheckBox Content="Minimiert starten" IsChecked="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox Content="Beim Schließen in den Tray minimieren" IsChecked="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox Content="Mit Windows starten" IsChecked="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox Content="Windows-Benachrichtigungen aktivieren" IsChecked="{x:Bind ViewModel.EnableWindowsNotifications, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox Content="Abhängigkeiten automatisch prüfen" IsChecked="{x:Bind ViewModel.AutoDependencyCheck, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource InfoCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Dienste" Style="{StaticResource SectionTitleStyle}" />
                            <CheckBox Content="AirPlay-Dienst aktivieren" IsChecked="{x:Bind ViewModel.EnableAirPlayService, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox Content="Android-Dienst aktivieren" IsChecked="{x:Bind ViewModel.EnableAndroidService, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                            <CheckBox Content="UxPlay/scrcpy nur im Hintergrund ausführen" IsChecked="{x:Bind ViewModel.RunBackgroundOnly, Mode=TwoWay}" Foreground="{StaticResource MdTextStrongBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource StatusCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Verbindung" Style="{StaticResource SectionTitleStyle}" />
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Header="Android TCP/IP-Host" Text="{x:Bind ViewModel.AndroidTcpHost, Mode=TwoWay}" />
                            <NumberBox Grid.Row="1" Header="TCP/IP-Port" Value="{x:Bind ViewModel.AndroidTcpPort, Mode=TwoWay}" />
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.SettingsPath, Mode=OneWay}" Style="{StaticResource BodySubtleStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Update &amp; Support" Style="{StaticResource SectionTitleStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Update prüfen" Style="{StaticResource SecondaryButtonStyle}" Click="OnCheckUpdateClicked" />
                            <Button Content="Update installieren" Style="{StaticResource PrimaryButtonStyle}" Click="OnInstallUpdateClicked" />
                        </StackPanel>
                        <Button Style="{StaticResource CoffeeButtonStyle}" HorizontalAlignment="Left" Click="OnBuyMeCoffeeClicked">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xECAF;" FontSize="16" />
                                <TextBlock Text="Buy me a coffee" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
