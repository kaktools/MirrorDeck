<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MirrorDeck.WinUI.Views.AirPlayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="AirPlayRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel Padding="14" Spacing="14">
                <Border Style="{StaticResource PageHeaderCard}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="AirPlay" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
                            <ScrollViewer Grid.Column="1" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Hidden" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Bonjour" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.BonjourInstalledText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Dienst" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.BonjourRunningText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}" Background="#1F2FBF78" BorderBrush="#4A2FBF78"><TextBlock Text="{x:Bind ViewModel.OverallStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="UxPlay-Empfänger starten und Bonjour-Status kontrollieren" Style="{StaticResource BodySubtleStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource ActionCard}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Grid ColumnSpacing="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch Grid.Column="0" Width="52" MinWidth="0" Padding="0" Margin="0,0,-6,0" Header="" OnContent="" OffContent="" IsOn="{x:Bind ViewModel.AutoStartOnAppStart, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <TextBlock Grid.Column="1" Text="Auto-Start" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Grid ColumnSpacing="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch Grid.Column="0" Width="52" MinWidth="0" Padding="0" Margin="0,0,-6,0" Header="" OnContent="" OffContent="" IsOn="{x:Bind ViewModel.AutoRestartOnFailure, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <TextBlock Grid.Column="1" Text="Auto-Restart" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Grid ColumnSpacing="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch Grid.Column="0" Width="52" MinWidth="0" Padding="0" Margin="0,0,-6,0" Header="" OnContent="" OffContent="" IsOn="{x:Bind ViewModel.RequirePinOnFirstConnect, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <TextBlock Grid.Column="1" Text="PIN bei erster Verbindung" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <TextBox Width="220" PlaceholderText="Zufällige PIN" MaxLength="4" Text="{x:Bind ViewModel.FixedPin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{x:Bind ViewModel.RequirePinOnFirstConnect, Mode=OneWay}" VerticalAlignment="Center" />
                        </StackPanel>

                        <ItemsControl>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid Orientation="Horizontal" HorizontalAlignment="Left" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78" Command="{x:Bind ViewModel.StartCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Play" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="Start" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="UxPlay-Empfänger starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E" Command="{x:Bind ViewModel.StopCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Stop" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Stop" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="UxPlay stoppen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF" Command="{x:Bind ViewModel.RestartCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="UxPlay neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSnapshotCardBrush}" BorderBrush="#6622B8CF" Command="{x:Bind ViewModel.RefreshBonjourStatusCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="World" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Bonjour-Status" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Dienststatus aktualisieren" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdPauseCardBrush}" BorderBrush="#66D79832" Command="{x:Bind ViewModel.RestartBonjourCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Sync" Foreground="{StaticResource MdWarningBrush}" />
                                            <TextBlock Text="Bonjour neu starten" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Bonjour-Service resetten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSurfaceAltBrush}" BorderBrush="#55334661" Command="{x:Bind ViewModel.CopyLogCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Copy" Foreground="{StaticResource MdTextStrongBrush}" />
                                            <TextBlock Text="Log kopieren" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Aktuelle AirPlay-Logs kopieren" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Expander Header="Logs anzeigen" IsExpanded="False" HorizontalAlignment="Stretch">
                    <Border Style="{StaticResource LogPanelStyle}" Margin="0,8,0,0">
                        <ScrollViewer MinHeight="180" MaxHeight="260">
                            <TextBlock
                                Text="{x:Bind ViewModel.LiveLog, Mode=OneWay}"
                                TextWrapping="Wrap"
                                IsTextSelectionEnabled="True"
                                Foreground="{StaticResource MdTextStrongBrush}"
                                FontFamily="{StaticResource MirrorDeckMonoFont}" />
                        </ScrollViewer>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
