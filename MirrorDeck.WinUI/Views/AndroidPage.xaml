<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MirrorDeck.WinUI.Views.AndroidPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="AndroidRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel Padding="14" Spacing="14">
                <Border Style="{StaticResource PageHeaderCard}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Android" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
                            <ScrollViewer Grid.Column="1" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Hidden" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Endpoint" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.TcpEndpoint, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="TCP" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.TcpStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Geräte" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.DeviceCountText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatusBadgeStyle}" Background="#1F2FBF78" BorderBrush="#4A2FBF78"><TextBlock Text="{x:Bind ViewModel.OverallStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="scrcpy über TCP/IP oder USB starten" Style="{StaticResource BodySubtleStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource ActionCard}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="18" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                    <ToggleSwitch Width="52" MinWidth="0" Padding="0" Margin="0,0,-6,0" Header="" OnContent="" OffContent="" IsOn="{x:Bind ViewModel.AutoStartOnAppStart, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <TextBlock Text="Auto-Start + TCP/IP" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                    <ToggleSwitch Width="52" MinWidth="0" Padding="0" Margin="0,0,-6,0" Header="" OnContent="" OffContent="" IsOn="{x:Bind ViewModel.AutoRestartOnFailure, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <TextBlock Text="Auto-Restart" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="Host" Style="{StaticResource BodySubtleStyle}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="2" Text="{x:Bind ViewModel.TcpHost, Mode=TwoWay}" PlaceholderText="IP oder Hostname" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Port" Style="{StaticResource BodySubtleStyle}" VerticalAlignment="Center" />
                            <NumberBox Grid.Column="4"
                                       Value="{x:Bind ViewModel.TcpPort, Mode=OneWay}"
                                       Minimum="1"
                                       Maximum="65535"
                                       SmallChange="1"
                                       LargeChange="10"
                                       ValidationMode="InvalidInputOverwritten"
                                       ValueChanged="OnTcpPortValueChanged"
                                       MinWidth="96"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <ItemsControl>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid Orientation="Horizontal" HorizontalAlignment="Left" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78" Command="{x:Bind ViewModel.ConnectTcpAndStartCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Play" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="Verbinden + Starten" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="TCP verbinden und Mirror starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF" Command="{x:Bind ViewModel.ConnectTcpCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="World" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Nur verbinden" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="ADB TCP-Verbindung herstellen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E" Command="{x:Bind ViewModel.DisconnectTcpCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="DisconnectDrive" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Trennen" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="TCP-Verbindung beenden" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78" Command="{x:Bind ViewModel.StartUsbCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Phone" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="USB starten" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Mirror über USB starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF" Command="{x:Bind ViewModel.RestartCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Neu starten" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="scrcpy-Session neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E" Command="{x:Bind ViewModel.StopCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Stop" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Stoppen" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Aktive Session beenden" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSnapshotCardBrush}" BorderBrush="#6622B8CF" Command="{x:Bind ViewModel.RefreshDevicesCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Sync" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Geräte aktualisieren" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="ADB-Device-Liste aktualisieren" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                                <Button Margin="0,0,10,10" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSurfaceAltBrush}" BorderBrush="#55334661" Command="{x:Bind ViewModel.CopyLogCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Copy" Foreground="{StaticResource MdTextStrongBrush}" />
                                            <TextBlock Text="Log kopieren" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Aktuelle Android-Logs kopieren" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Kurzer Hinweis" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Für die drahtlose Android-Kopplung zuerst Entwickleroptionen und USB-Debugging aktivieren, dann einmal per USB verbinden und Debugging erlauben." Style="{StaticResource BodySubtleStyle}" TextWrapping="Wrap" />
                        <TextBlock Text="Die komplette Schritt-für-Schritt-Anleitung findest du in der Hilfe unter 'Mini-Kurzfassung Android'." Style="{StaticResource BodySubtleStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="12" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource InfoCard}" HorizontalAlignment="Left" Width="150">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Geräte" Style="{StaticResource SectionTitleStyle}" />
                            <ScrollViewer MinHeight="56" VerticalAlignment="Top" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}" />
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Expander Grid.Column="1" Header="Logs anzeigen" IsExpanded="False" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                        <Border Style="{StaticResource LogPanelStyle}" Margin="0,0,0,0">
                            <ScrollViewer MinHeight="160" MaxHeight="260">
                                <TextBlock
                                    Text="{x:Bind ViewModel.LiveLog, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True"
                                    Foreground="{StaticResource MdTextStrongBrush}"
                                    FontFamily="{StaticResource MirrorDeckMonoFont}" />
                            </ScrollViewer>
                        </Border>
                    </Expander>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
