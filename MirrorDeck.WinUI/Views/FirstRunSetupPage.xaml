<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MirrorDeck.WinUI.Views.FirstRunSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource MirrorDeckPageBackgroundBrush}">

    <Grid>
        <Image Style="{StaticResource PageWatermarkImageStyle}" Opacity="0.045" Width="640" Height="640" />

        <Grid Padding="32,24,32,22" MaxWidth="920" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="10" HorizontalAlignment="Center">
                <Image Source="ms-appx:///Assets/MirrorDeckLogo.png" Width="72" Height="72" HorizontalAlignment="Center" VerticalAlignment="Center" />

                <TextBlock
                    Text="Willkommen bei MirrorDeck"
                    FontFamily="{StaticResource MirrorDeckDisplayFont}"
                    FontSize="34"
                    Foreground="{StaticResource MdTextStrongBrush}"
                    HorizontalAlignment="Center"
                    TextAlignment="Center" />

                <TextBlock
                    Text="Wähle, welche Mirroring-Module du aktivieren möchtest.&#x0a;Du kannst das später jederzeit in den Einstellungen ändern."
                    FontFamily="{StaticResource MirrorDeckBodyFont}"
                    FontSize="14"
                    Foreground="{StaticResource MdTextMutedBrush}"
                    TextWrapping="WrapWholeWords"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    MaxWidth="620" />

                <Border Height="1" Width="620" Margin="0,2,0,0" Background="{StaticResource MdInfoBrush}" Opacity="0.55" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,18,0,0" ColumnSpacing="12" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="AirPlayCard"
                    Grid.Column="0"
                    Height="210"
                    Padding="16,12"
                    CornerRadius="16"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    BorderThickness="1"
                    Background="{StaticResource MdSurfaceBrush}"
                    BorderBrush="{StaticResource MdBorderBrush}"
                    Click="OnAirPlayCardClick">
                    <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                            <Border x:Name="AirPlayIconHost" Width="44" Height="44" CornerRadius="11" Background="{StaticResource MdSurfaceAltBrush}" BorderBrush="{StaticResource MdBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon x:Name="AirPlayIcon" Glyph="&#xE7F4;" FontSize="21" Foreground="{StaticResource MdTextStrongBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="AirPlay" FontFamily="{StaticResource MirrorDeckDisplayFont}" FontSize="30" Foreground="{StaticResource MdTextStrongBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="UxPlay-Receiver für iPhone, iPad und macOS" FontFamily="{StaticResource MirrorDeckBodyFont}" FontSize="13" Foreground="{StaticResource MdTextMutedBrush}" TextWrapping="WrapWholeWords" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="520" />
                        <TextBlock x:Name="AirPlayStateHint" Text="Inaktiv" FontFamily="{StaticResource MirrorDeckMonoFont}" FontSize="11" Foreground="{StaticResource MdTextMutedBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button
                    x:Name="AndroidCard"
                    Grid.Column="1"
                    Height="210"
                    Padding="16,12"
                    CornerRadius="16"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    BorderThickness="1"
                    Background="{StaticResource MdSurfaceBrush}"
                    BorderBrush="{StaticResource MdBorderBrush}"
                    Click="OnAndroidCardClick">
                    <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                            <Border x:Name="AndroidIconHost" Width="44" Height="44" CornerRadius="11" Background="{StaticResource MdSurfaceAltBrush}" BorderBrush="{StaticResource MdBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon x:Name="AndroidIcon" Glyph="&#xE70A;" FontSize="21" Foreground="{StaticResource MdTextStrongBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Android" FontFamily="{StaticResource MirrorDeckDisplayFont}" FontSize="30" Foreground="{StaticResource MdTextStrongBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Screen-Mirroring über scrcpy und adb" FontFamily="{StaticResource MirrorDeckBodyFont}" FontSize="13" Foreground="{StaticResource MdTextMutedBrush}" TextWrapping="WrapWholeWords" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="520" />
                        <TextBlock x:Name="AndroidStateHint" Text="Inaktiv" FontFamily="{StaticResource MirrorDeckMonoFont}" FontSize="11" Foreground="{StaticResource MdTextMutedBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <StackPanel
                Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <Button
                    x:Name="ConfirmButton"
                    Content="Weiter"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="180"
                    Click="OnConfirmClick" />

                <Button
                    Style="{StaticResource CoffeeButtonStyle}"
                    Click="OnBuyMeCoffeeClicked">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xECAF;" FontSize="16" />
                        <TextBlock Text="Buy me a coffee" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
