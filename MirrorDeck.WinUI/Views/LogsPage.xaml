<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MirrorDeck.WinUI.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <Grid Padding="14" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PageHeaderCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Logs" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Ruhige Ansicht für App-, UxPlay-, scrcpy- und Setup-Meldungen" Style="{StaticResource BodySubtleStyle}" />
                    </StackPanel>

                    <ItemsControl Grid.Column="1" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid Orientation="Horizontal" HorizontalAlignment="Right" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <Button Margin="0,0,8,8" Content="Datei öffnen" Style="{StaticResource NeutralButtonStyle}" Command="{x:Bind ViewModel.OpenLogFileCommand}" />
                        <Button Margin="0,0,8,8" Content="Kopieren" Style="{StaticResource SecondaryButtonStyle}" Command="{x:Bind ViewModel.CopyCommand}" />
                        <Button Margin="0,0,0,8" Content="Leeren" Style="{StaticResource DangerButtonStyle}" Command="{x:Bind ViewModel.ClearCommand}" />
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource InfoCard}">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="240" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Quelle" VerticalAlignment="Center" Style="{StaticResource BodySubtleStyle}" />
                    <ComboBox Grid.Column="1" ItemsSource="{x:Bind ViewModel.Sources}" SelectedItem="{x:Bind ViewModel.SelectedSource, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource LogPanelStyle}">
                <ListView ItemsSource="{x:Bind ViewModel.FilteredEntries, Mode=OneWay}" Background="Transparent" BorderThickness="0" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusBadgeStyle}" Margin="0,0,0,6" Padding="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Timestamp}" Style="{StaticResource BodySubtleStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Source}" Foreground="{StaticResource MdTextStrongBrush}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" Foreground="{StaticResource MdTextStrongBrush}" FontFamily="{StaticResource MirrorDeckMonoFont}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>
    </Grid>
</Page>
