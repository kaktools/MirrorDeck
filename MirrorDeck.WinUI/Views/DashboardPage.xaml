<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MirrorDeck.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="DashboardRoot" Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Image Style="{StaticResource PageWatermarkImageStyle}" />
        <ScrollViewer>
            <StackPanel Padding="14" Spacing="14">
                <Border Style="{StaticResource ActionCard}" Visibility="{x:Bind ViewModel.AirPlayControlsVisibility, Mode=OneWay}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="AirPlay" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                <TextBlock Text="Status:" Style="{StaticResource BodySubtleStyle}" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.AirPlaySessionStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{x:Bind ViewModel.AirPlayStatusChipsVisibility, Mode=OneWay}">
                                <Border Style="{StaticResource StatusBadgeStyle}" Background="{x:Bind ViewModel.BonjourChipBackground, Mode=OneWay}" BorderBrush="{x:Bind ViewModel.BonjourChipBorderBrush, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Bonjour" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.BonjourStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatusBadgeStyle}" Background="{x:Bind ViewModel.UxPlayChipBackground, Mode=OneWay}" BorderBrush="{x:Bind ViewModel.UxPlayChipBorderBrush, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="UxPlay" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.UxPlayStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78" Command="{x:Bind ViewModel.StartAirPlayAsyncCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Play" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="Start" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="AirPlay-Mirror starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E" Command="{x:Bind ViewModel.StopAirPlayAsyncCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Stop" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Stop" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="AirPlay-Mirror stoppen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF" Command="{x:Bind ViewModel.RestartAirPlayAsyncCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="AirPlay neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ActionCard}" Visibility="{x:Bind ViewModel.AndroidControlsVisibility, Mode=OneWay}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Android" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                <TextBlock Text="Status:" Style="{StaticResource BodySubtleStyle}" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.AndroidSessionStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{x:Bind ViewModel.AndroidStatusChipsVisibility, Mode=OneWay}">
                                <Border Style="{StaticResource StatusBadgeStyle}" Background="{x:Bind ViewModel.ScrcpyChipBackground, Mode=OneWay}" BorderBrush="{x:Bind ViewModel.ScrcpyChipBorderBrush, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="scrcpy" Style="{StaticResource BodySubtleStyle}" /><TextBlock Text="{x:Bind ViewModel.ScrcpyStatusText, Mode=OneWay}" Foreground="{StaticResource MdTextStrongBrush}" /></StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStartCardBrush}" BorderBrush="#552FBF78" Command="{x:Bind ViewModel.StartAndroidTcpAsyncCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Play" Foreground="{StaticResource MdSuccessBrush}" />
                                            <TextBlock Text="Start" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Android-Mirror starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdStopCardBrush}" BorderBrush="#66E45A6E" Command="{x:Bind ViewModel.StopAndroidAsyncCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Stop" Foreground="{StaticResource MdDangerBrush}" />
                                            <TextBlock Text="Stop" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Android-Mirror stoppen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF" Command="{x:Bind ViewModel.RestartAndroidAsyncCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Android neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusCard}" Visibility="{x:Bind ViewModel.GlobalActionsVisibility, Mode=OneWay}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Globale Aktionen" Style="{StaticResource SectionTitleStyle}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdRestartCardBrush}" BorderBrush="#663CA8FF" Command="{x:Bind ViewModel.RestartAllCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MdInfoBrush}" />
                                            <TextBlock Text="Restart All" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Alle laufenden Sessions neu starten" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdPauseCardBrush}" BorderBrush="#66D79832" Command="{x:Bind ViewModel.TogglePauseCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Pause" Foreground="{StaticResource MdWarningBrush}" />
                                            <TextBlock Text="Pause / Play" Style="{StaticResource SectionTitleStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind ViewModel.PauseResumeLabel, Mode=OneWay}" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Margin="0" HorizontalAlignment="Stretch" Width="Auto" Style="{StaticResource ActionTileButtonStyle}" Background="{StaticResource MdSnapshotCardBrush}" BorderBrush="#6622B8CF" Command="{x:Bind ViewModel.SnapshotCommand}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <SymbolIcon Grid.Column="0" Symbol="Camera" Foreground="{StaticResource MdInfoBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="Snapshot" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="Fenster-Screenshot erstellen" Style="{StaticResource BodySubtleStyle}" TextAlignment="Center" HorizontalAlignment="Center" />
                                    </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
