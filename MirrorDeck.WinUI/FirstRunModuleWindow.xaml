<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MirrorDeck.WinUI.FirstRunModuleWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MirrorDeck - Erstes Setup">

    <Grid Background="{StaticResource MirrorDeckPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1AFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1">
            <Grid x:Name="PopupTitleBarDragRegion" Padding="10,0,8,0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="22" Height="22" CornerRadius="6" Background="#223CA8FF" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/MirrorDeckLogo.png" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="MirrorDeck" FontFamily="{StaticResource MirrorDeckDisplayFont}" FontSize="14" Foreground="{StaticResource MdTextStrongBrush}" />
                    <TextBlock Text="Module auswählen" Style="{StaticResource BodySubtleStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Welche Module möchtest du aktivieren?" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="Diese Auswahl wird als Startkonfiguration gespeichert und kann später jederzeit im Setup geändert werden." Style="{StaticResource BodySubtleStyle}" TextWrapping="WrapWholeWords" />

            <ItemsControl Grid.Row="2" Margin="0,16,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid Orientation="Horizontal" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ToggleButton x:Name="AirPlayToggle" IsChecked="True" Margin="0,0,12,12" Width="260" Height="120" Background="#1C2B4A" BorderBrush="#4D3CA8FF" BorderThickness="1" CornerRadius="14">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <SymbolIcon Symbol="Video" Foreground="{StaticResource MdInfoBrush}" />
                        <TextBlock Text="AirPlay" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="UxPlay-Receiver aktivieren" Style="{StaticResource BodySubtleStyle}" HorizontalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="AndroidToggle" IsChecked="True" Margin="0,0,12,12" Width="260" Height="120" Background="#1C2B4A" BorderBrush="#4D3CA8FF" BorderThickness="1" CornerRadius="14">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <SymbolIcon Symbol="Phone" Foreground="{StaticResource MdInfoBrush}" />
                        <TextBlock Text="Android" Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="scrcpy/adb aktivieren" Style="{StaticResource BodySubtleStyle}" HorizontalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
            </ItemsControl>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Standard" Style="{StaticResource SecondaryButtonStyle}" Click="OnUseDefaultsClick" />
                <Button Content="Bestätigen &amp; starten" Style="{StaticResource PrimaryButtonStyle}" Click="OnConfirmClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
